{
  "name": "ompay.js",
  "version": "0.2.0",
  "description": "Unofficial SDK for OMPAY Payment Gateway integration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run --no-ci",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ompay",
    "payment",
    "gateway",
    "oman",
    "sdk",
    "payment-gateway",
    "checkout"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m7medVision/ompay.js.git"
  },
  "bugs": {
    "url": "https://github.com/m7medVision/ompay.js/issues"
  },
  "homepage": "https://github.com/m7medVision/ompay.js#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "semantic-release": "^24.2.9",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.46.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
